@baseUrl = https://financeiro-back.onrender.com
# @baseUrl = http://192.168.1.108:3333
@authToken = {{authenticate.response.body.access_token}}

###
# @name authenticate
POST {{baseUrl}}/sessions
Content-Type: application/json

{
	"email": "admin@admin.com",
	"password": "admin"
}

###
# @name refresh_token
POST {{baseUrl}}/sessions/refresh
Content-Type: application/json

{
	"refresh_token": "uuid-do-refresh-token"
}

###
# @name logout
POST {{baseUrl}}/sessions/logout
Content-Type: application/json

{
	"refresh_token": "uuid-do-refresh-token"
}

###

# @name create_account
POST {{baseUrl}}/accounts
Content-Type: application/json

{
	"email": "admin@admin.com",
	"name": "Matheus Gabriel",
	"password": "admin"
}

###

