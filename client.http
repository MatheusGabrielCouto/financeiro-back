	"icon": "star",
	"color": "#F59E0B",
	"parentId": "uuid-da-categoria-pai"
}

###

# @name update_category
PATCH {{baseUrl}}/category/00000000-0000-0000-0000-000000000000
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
	"title": "Novo titulo",
	"icon": "heart",
	"color": "#EF4444"
}

###

# @name delete_category
DELETE {{baseUrl}}/category/00000000-0000-0000-0000-000000000000
