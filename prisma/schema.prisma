// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  amount    Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  categories        Category[]
  categoryBudgets   CategoryBudget[]
  debts             Debt[]
  transactions      Transaction[]
  futurePurchases   FuturePurchase[]
  recurringIncomes  RecurringIncome[]
  recurringPayments RecurringPayment[]
  pushTokens        PushToken[]

  @@map("users")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_tokens")
}

model RecurringPayment {
  id              String    @id @default(uuid())
  title           String
  value           Float
  dayOfMonth      Int
  lastProcessedAt DateTime?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("recurring_payments")
}

model RecurringIncome {
  id              String    @id @default(uuid())
  title           String
  value           Float
  dayOfMonth      Int
  lastProcessedAt DateTime?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("recurring_incomes")
}

model Category {
  id          String @id @default(uuid())
  title       String
  description String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions TransactionOnCategory[]
  budgets      CategoryBudget[]
  createdAt    DateTime                @default(now()) @map("created_at")

  @@map("categories")
}

model CategoryBudget {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  amount     Float
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, categoryId, month, year])
  @@map("category_budgets")
}

model Transaction {
  id          String  @id @default(uuid())
  value       Float
  message     String
  isRecurring Boolean @default(false) @map("is_recurring")

  userId String
  user   User   @relation(fields: [userId], references: [id])

  categories TransactionOnCategory[]
  type       TypeTransaction

  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

model TransactionOnCategory {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([transactionId, categoryId])
  @@map("transaction_categories")
}

model Debt {
  id          String @id @default(uuid())
  title       String
  description String

  recurrence RecurrenceType @default(MONTHLY)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  installments Installment[]
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("debts")
}

model Installment {
  id              String            @id @default(uuid())
  value           Float
  status          StatusInstallment
  order           Float
  dateTransaction DateTime
  createdAt       DateTime          @default(now()) @map("created_at")

  debtId String
  debt   Debt   @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("installments")
}

model FuturePurchase {
  id              String   @id @default(uuid())
  name            String
  value           Float
  valueAdded      Float    @map("value_added")
  dateAcquisition DateTime @map("date_acquisition")
  createdAt       DateTime @default(now()) @map("created_at")
  image           String?

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("future_purchases")
}

enum TypeTransaction {
  DEBIT
  CREDIT
  PAY
}

enum StatusInstallment {
  PAY
  SCHEDULE
}

enum RecurrenceType {
  MONTHLY
  WEEKLY
  DAILY
  YEARLY
}
