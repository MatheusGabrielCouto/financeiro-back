// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  amount Float @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  categories Category[]
  debts Debt[]
  transactions Transaction[]
  futurePurchases FuturePurchase[]
  @@map("users")
}

model Category {
  id String @id @default(uuid())
  title String
  description String

  userId String
  user User @relation(fields: [userId], references: [id])

  transactions TransactionOnCategory[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Transaction {
  id String @id @default(uuid())
  value Float
  message String

  userId String
  user User @relation(fields: [userId], references: [id])

  categories TransactionOnCategory[]
  type TypeTransaction

  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}


model TransactionOnCategory {
  transactionId String
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  categoryId    String
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([transactionId, categoryId])
  @@map("transaction_categories")
}

model Debt {
  id String @id @default(uuid())
  title String
  description String

  userId String
  user User @relation(fields: [userId], references: [id])

  installments Installment[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("debts")
}

model Installment {
  id String @id @default(uuid())
  value Float
  status StatusInstallment
  order Float
  dateTransaction DateTime
  createdAt DateTime @default(now()) @map("created_at")

  debtId String
  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("installments")
}

model FuturePurchase {
  id String @id @default(uuid())
  name String
  value Float
  valueAdded Float @map("value_added")
  dateAcquisition DateTime @map("date_acquisition")
  createdAt DateTime @default(now()) @map("created_at")
  image String

  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])

  @@map("future_purchases")
}

enum TypeTransaction {
  DEBIT
  CREDIT
  PAY
}

enum StatusInstallment {
  PAY
  SCHEDULE
}
